import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String A = sc.next();
        String B = sc.next();
        
        // 1. Sum the lengths
        System.out.println(A.length() + B.length());
        
        // 2. Compare lexicographically (Dictionary order)
        // If A.compareTo(B) > 0, it means A comes after B in the dictionary
        if (A.compareTo(B) > 0) {
            System.out.println("Yes");
        } else {
            System.out.println("No");
        }
        
        // 3. Capitalize first letter and print
        // substring(0, 1) gets the first letter, substring(1) gets the rest
        String capitalizedA = A.substring(0, 1).toUpperCase() + A.substring(1);
        String capitalizedB = B.substring(0, 1).toUpperCase() + B.substring(1);
        
        System.out.println(capitalizedA + " " + capitalizedB);
    }
}


