import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int i = 1; // This counts our lines

        // "While there is a next line to read..."
        while (sc.hasNext()) {
            String s = sc.nextLine(); // Get the text
            System.out.println(i + " " + s); // Print number + text
            i++; // Increase the count for the next line
        }
    }
}
